{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "NODE_ENV=production node .output/server/index.mjs",
    "build": "nuxt build",
    "clean": "rimraf .nuxt dist .cache .output node_modules .lighthouseci .vercel .unlighthouse",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint:js": "eslint --ext \".ts,.vue\" --ignore-path .gitignore .",
    "lint:prettier": "prettier --check .",
    "lint": "yarn lint:js && yarn lint:prettier",
    "lintfix": "prettier --write --list-different . && pnpm lint:js --fix"
  },
  "devDependencies": {
    "@nuxt/devtools": "latest",
    "@nuxt/image": "^1.1.0",
    "@nuxtjs/color-mode": "^3.3.2",
    "@nuxtjs/eslint-config-typescript": "^12.1.0",
    "@nuxtjs/eslint-module": "^4.1.0",
    "@nuxtjs/google-fonts": "^3.1.0",
    "@nuxtjs/i18n": "^8",
    "@nuxtjs/seo": "2.0.0-rc.9",
    "@rushstack/eslint-patch": "^1.6.0",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.0.0",
    "@typescript-eslint/parser": "^6.13.1",
    "@vue/eslint-config-prettier": "^8.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "cross-var": "^1.1.0",
    "dotenv": "^16.3.1",
    "dotenv-cli": "^7.3.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-config-universe": "^12.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "nuxt": "^3.8.2",
    "nuxt-icon": "^0.6.6",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "sass": "^1.69.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.3.2",
    "vue": "^3.3.8",
    "vue-eslint-parser": "^9.3.2",
    "vue-router": "^4.2.5"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.16",
    "@nuxt/content": "2.10.0",
    "uuid": "^9.0.1"
  },
  "packageManager": "pnpm@9.1.1"
